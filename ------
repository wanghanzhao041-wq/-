    <span>Custom Sculpture</span><span class="dot">◆</span>
  </div>
</div>

<!-- ABOUT -->
<section class="about">
  <div class="about-left">
    <div class="about-label reveal">关于我们</div>
    <h2 class="about-title reveal reveal-delay-1">
      以钢铁诠释<em>永恒</em>之美
    </h2>
    <p class="about-text reveal reveal-delay-2">
      欧度雕塑，扎根于中国雕塑之乡河北曲阳，专注不锈钢景观雕塑的设计与制造超过15年。
      每一件作品都是一次对材料极限的探索——从毛坯到镜面，从概念到永恒。
    </p>
    <p class="about-text reveal reveal-delay-2">
      我们的作品遍布全球各地的公园、广场、酒店与私人庄园，
      以独特的光影语言讲述着金属与空间之间的永恒对话。
    </p>
    <div class="about-stats reveal reveal-delay-3">
      <div>
        <div class="stat-num">15+</div>
        <div class="stat-label">年制造经验</div>
      </div>
      <div>
        <div class="stat-num">800+</div>
        <div class="stat-label">完成作品</div>
      </div>
      <div>
        <div class="stat-num">40+</div>
        <div class="stat-label">出口国家</div>
      </div>
      <div>
        <div class="stat-num">∞</div>
        <div class="stat-label">定制可能</div>
      </div>
    </div>
  </div>
  <div class="about-visual reveal reveal-delay-2">
    <div class="about-img-frame">
      <svg class="sculpture-svg" width="240" height="320" viewBox="0 0 240 320">
        <!-- Abstract sculpture form -->
        <defs>
          <linearGradient id="sculpt1" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#e8e0d0;stop-opacity:.9"/>
            <stop offset="50%" style="stop-color:#c8a050;stop-opacity:.7"/>
            <stop offset="100%" style="stop-color:#8b6a30;stop-opacity:.5"/>
          </linearGradient>
          <filter id="blur1"><feGaussianBlur stdDeviation="2"/></filter>
        </defs>
        <!-- Base -->
        <ellipse cx="120" cy="300" rx="70" ry="10" fill="rgba(200,160,80,.15)" filter="url(#blur1)"/>
        <!-- Body -->
        <path d="M80 280 Q60 200 90 140 Q110 80 120 40 Q130 80 150 140 Q180 200 160 280 Z" fill="url(#sculpt1)" opacity=".8"/>
        <!-- Reflection highlight -->
        <path d="M100 260 Q85 190 105 140 Q115 100 120 60" stroke="rgba(255,255,255,.4)" stroke-width="2" fill="none"/>
        <!-- Second form -->
        <path d="M60 270 Q40 210 70 160 Q85 120 95 90 Q100 120 90 160 Q85 210 90 270 Z" fill="url(#sculpt1)" opacity=".4" transform="rotate(-15, 80, 180)"/>
        <!-- Shine point -->
        <circle cx="108" cy="120" r="4" fill="rgba(255,255,255,.6)"/>
        <circle cx="108" cy="120" r="12" fill="rgba(255,255,255,.1)"/>
      </svg>
      <div class="about-img-year">15</div>
    </div>
  </div>
</section>

<!-- WORKS -->
<section class="works">
  <div class="section-header reveal">
    <h2 class="section-title">代表<em>作品</em></h2>
    <span class="section-count">— 精选系列 / 2024</span>
  </div>

  <div class="works-grid">
    <!-- Card 1 - Large -->
    <div class="work-card" style="background:#0a0a0a; overflow:hidden;">
      <div class="work-visual" style="position:relative;width:100%;height:100%;overflow:hidden;">
        <img src="https://images.unsplash.com/photo-1620503374956-c942862f0372?auto=format&fit=crop&w=800&q=85" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.6) saturate(.8);transition:transform .8s ease;" class="work-bg" alt="雕塑作品1">
        <svg width="0" height="0" viewBox="0 0 0 0">
          <defs>
