<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OUDU SCULPTURE — 欧度雕塑</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,600&family=Noto+Serif+SC:wght@300;400&family=Space+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0c0b09;
  --paper: #f5f0e8;
  --warm: #d4b896;
  --gold: #c8a050;
  --rust: #8b4a2a;
  --silver: #9aa0a8;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  background: var(--ink);
  color: var(--paper);
  font-family: 'Noto Serif SC', serif;
  font-weight: 300;
  overflow-x: hidden;
  cursor: none;
}

/* CUSTOM CURSOR */
.cursor {
  position: fixed;
  width: 8px; height: 8px;
  background: var(--gold);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.1s;
  mix-blend-mode: difference;
}
.cursor-ring {
  position: fixed;
  width: 36px; height: 36px;
  border: 1px solid rgba(200,160,80,.5);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  transition: transform 0.25s ease, width 0.3s, height 0.3s;
  transform: translate(-14px,-14px);
}

/* NOISE OVERLAY */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 1000;
  opacity: 0.4;
}

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 500;
  padding: 28px 60px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  mix-blend-mode: normal;
}
nav::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(12,11,9,.8) 0%, transparent 100%);
  pointer-events: none;
}
.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 300;
  letter-spacing: 6px;
  color: var(--paper);
  text-decoration: none;
  position: relative;
}
.nav-links {
  display: flex;
  gap: 40px;
  list-style: none;
  position: relative;
}
.nav-links a {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 3px;
  color: rgba(245,240,232,.5);
  text-decoration: none;
  text-transform: uppercase;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--gold); }

/* HERO */
.hero {
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 30% 60%, rgba(139,74,42,.15) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 20%, rgba(200,160,80,.08) 0%, transparent 50%);
}

/* Animated grid lines */
.grid-lines {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(200,160,80,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,160,80,.04) 1px, transparent 1px);
  background-size: 80px 80px;
  animation: gridShift 20s linear infinite;
}
@keyframes gridShift {
  from { transform: translateY(0); }
  to { transform: translateY(80px); }
}

.hero-content {
  text-align: center;
  position: relative;
  z-index: 2;
}

.hero-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 8px;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 32px;
  opacity: 0;
  animation: fadeUp 1s ease 0.3s forwards;
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(64px, 12vw, 160px);
  font-weight: 300;
  line-height: 0.9;
  letter-spacing: -2px;
  color: var(--paper);
  opacity: 0;
  animation: fadeUp 1.2s ease 0.5s forwards;
}

.hero-title em {
  font-style: italic;
  color: var(--gold);
  display: block;
}

.hero-subtitle {
  font-size: 14px;
  color: rgba(245,240,232,.4);
  letter-spacing: 4px;
  margin-top: 40px;
  opacity: 0;
  animation: fadeUp 1s ease 0.9s forwards;
}

.hero-scroll {
  position: absolute;
  bottom: 48px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  opacity: 0;
  animation: fadeUp 1s ease 1.4s forwards;
}
.hero-scroll span {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 4px;
  color: rgba(245,240,232,.3);
  text-transform: uppercase;
}
.scroll-line {
  width: 1px;
  height: 60px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); }
  50% { opacity: 1; transform: scaleY(1.2); }
}

/* Large decorative number */
.hero-num {
  position: absolute;
  right: 5%;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'Cormorant Garamond', serif;
  font-size: 280px;
  font-weight: 300;
  color: rgba(245,240,232,.03);
  line-height: 1;
  user-select: none;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ABOUT SECTION */
.about {
  padding: 160px 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 120px;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
}

.about-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 5px;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.about-label::before {
  content: '';
  width: 40px;
  height: 1px;
  background: var(--gold);
  opacity: 0.4;
}

.about-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 52px;
  font-weight: 300;
  line-height: 1.2;
  margin-bottom: 32px;
}
.about-title em { font-style: italic; color: var(--gold); }

.about-text {
  font-size: 15px;
  color: rgba(245,240,232,.55);
  line-height: 2.2;
  margin-bottom: 16px;
}

.about-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  margin-top: 48px;
  padding-top: 48px;
  border-top: 1px solid rgba(245,240,232,.08);
}

.stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 48px;
  font-weight: 300;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 6px;
}
.stat-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 3px;
  color: rgba(245,240,232,.35);
  text-transform: uppercase;
}

/* Right visual */
.about-visual {
  position: relative;
}

.about-img-frame {
  position: relative;
  height: 600px;
  background: linear-gradient(135deg, rgba(139,74,42,.2), rgba(200,160,80,.1));
  border: 1px solid rgba(200,160,80,.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.about-img-frame::before {
  content: '';
  position: absolute;
  inset: 20px;
  border: 1px solid rgba(200,160,80,.06);
}

/* SVG sculpture simulation */
.sculpture-svg {
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 0 40px rgba(200,160,80,.2));
  animation: float 6s ease-in-out infinite;
}
@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-12px) rotate(1deg); }
  66% { transform: translateY(-6px) rotate(-0.5deg); }
}

.about-img-year {
  position: absolute;
  bottom: 24px;
  right: 24px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 80px;
  font-weight: 300;
  color: rgba(200,160,80,.1);
  line-height: 1;
}

/* WORKS SECTION */
.works {
  padding: 120px 60px;
  max-width: 1400px;
  margin: 0 auto;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 80px;
  padding-bottom: 32px;
  border-bottom: 1px solid rgba(245,240,232,.08);
}

.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 64px;
  font-weight: 300;
  line-height: 1;
}
.section-title em { font-style: italic; color: var(--gold); }

.section-count {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: 3px;
  color: rgba(245,240,232,.3);
}

.works-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 3px;
}

.work-card {
  position: relative;
  overflow: hidden;
  cursor: none;
}

.work-card:first-child {
  grid-row: 1 / 3;
  height: 680px;
}

.work-card:not(:first-child) {
  height: 338px;
}

.work-bg {
  width: 100%;
  height: 100%;
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.work-card:hover .work-bg {
  transform: scale(1.06);
}

/* SVG artwork placeholders */
.work-visual {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.work-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(12,11,9,.9) 0%, transparent 50%);
  opacity: 0;
  transition: opacity 0.4s;
}
.work-card:hover .work-overlay { opacity: 1; }

.work-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32px 28px;
  transform: translateY(20px);
  opacity: 0;
  transition: all 0.4s ease;
}
.work-card:hover .work-info {
  opacity: 1;
  transform: translateY(0);
}

.work-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 300;
  margin-bottom: 6px;
}
.work-meta {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--gold);
  text-transform: uppercase;
}

/* PROCESS */
.process {
  background: var(--paper);
  color: var(--ink);
  padding: 160px 60px;
}

.process-inner {
  max-width: 1400px;
  margin: 0 auto;
}

.process-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 80px;
  font-weight: 300;
  line-height: 0.9;
  margin-bottom: 100px;
  color: var(--ink);
}
.process-title em { font-style: italic; color: var(--rust); }

.process-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 60px;
}

.process-step {
  position: relative;
}

.step-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 96px;
  font-weight: 300;
  color: rgba(12,11,9,.06);
  line-height: 1;
  margin-bottom: -20px;
}

.step-line {
  width: 40px;
  height: 1px;
  background: var(--rust);
  margin-bottom: 20px;
  opacity: 0.4;
}

.step-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 400;
  margin-bottom: 14px;
  color: var(--ink);
}

.step-text {
  font-size: 13px;
  line-height: 2;
  color: rgba(12,11,9,.55);
}

/* CONTACT */
.contact {
  padding: 160px 60px;
  max-width: 1400px;
  margin: 0 auto;
  text-align: center;
}

.contact-pre {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 6px;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 32px;
}

.contact-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(48px, 8vw, 100px);
  font-weight: 300;
  line-height: 0.95;
  margin-bottom: 60px;
}
.contact-title em { font-style: italic; color: var(--gold); display: block; }

.contact-btn {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  padding: 20px 48px;
  border: 1px solid rgba(200,160,80,.3);
  color: var(--gold);
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: 4px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.4s;
  position: relative;
  overflow: hidden;
}

.contact-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gold);
  transform: translateX(-100%);
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.contact-btn:hover {
  color: var(--ink);
}
.contact-btn:hover::before { transform: translateX(0); }

.contact-btn span { position: relative; z-index: 1; }

.contact-arrow {
  position: relative;
  z-index: 1;
  font-size: 18px;
  transition: transform 0.3s;
}
.contact-btn:hover .contact-arrow { transform: translateX(6px); }

/* FOOTER */
footer {
  border-top: 1px solid rgba(245,240,232,.06);
  padding: 40px 60px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  letter-spacing: 6px;
  color: rgba(245,240,232,.3);
}

.footer-copy {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 2px;
  color: rgba(245,240,232,.2);
}

/* SCROLL REVEAL */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.9s ease, transform 0.9s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-delay-1 { transition-delay: 0.15s; }
.reveal-delay-2 { transition-delay: 0.3s; }
.reveal-delay-3 { transition-delay: 0.45s; }
.reveal-delay-4 { transition-delay: 0.6s; }

/* Horizontal marquee */
.marquee-section {
  overflow: hidden;
  border-top: 1px solid rgba(245,240,232,.06);
  border-bottom: 1px solid rgba(245,240,232,.06);
  padding: 24px 0;
  background: rgba(200,160,80,.03);
}

.marquee-track {
  display: flex;
  white-space: nowrap;
  animation: marquee 20s linear infinite;
}

.marquee-track span {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  font-style: italic;
  color: rgba(245,240,232,.25);
  letter-spacing: 4px;
  padding: 0 40px;
}

.marquee-track .dot {
  color: var(--gold);
  font-style: normal;
  font-size: 6px;
}

@keyframes marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<nav>
  <a href="#" class="nav-logo">OUDU</a>
  <ul class="nav-links">
    <li><a href="#">作品</a></li>
    <li><a href="#">工艺</a></li>
    <li><a href="#">关于</a></li>
    <li><a href="#">联系</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="grid-lines"></div>
  <div class="hero-num">欧</div>
  <div class="hero-content">
    <div class="hero-eyebrow">曲阳 · 河北 · 中国 · EST. 2008</div>
    <h1 class="hero-title">
      OUDU
